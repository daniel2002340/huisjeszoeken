{
  "name": "huisjeszoeken",
  "version": "1.0.0",
  "description": "Personal rental alert system for Delft (see PLAN.md)",
  "type": "module",
  "main": "dist/index.js",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "DRY_RUN=true SCRAPERS_ENABLED=false DASHBOARD_PASSWORD=${DASHBOARD_PASSWORD:-admin} tsx watch src/index.ts",
    "dev:scrape": "DRY_RUN=true DASHBOARD_PASSWORD=${DASHBOARD_PASSWORD:-admin} tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "web:dev": "vite --config src/web/vite.config.ts",
    "web:build": "vite build --config src/web/vite.config.ts",
    "web:typecheck": "tsc -p src/web/tsconfig.json",
    "test": "vitest run",
    "fixture": "tsx scripts/fixture.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "^12.2.0",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.4.0",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "undici": "^8.5.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.2",
    "playwright": "^1.61.1",
    "tsx": "^4.20.3",
    "typescript": "^5.5.3",
    "vite": "^8.1.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "private": true
}
