# Copy to .env and adjust. All variables are read by src/core/config.ts
# (zod-validated); docker-compose.yml also interpolates TAILSCALE_IP and PORT.

# --- Core ---------------------------------------------------------------
NODE_ENV=production

# Safety switch (CLAUDE.md): true = log rendered emails instead of sending.
# Only set to false on the Mac Mini once SMTP below is configured.
DRY_RUN=true

# Dashboard/API port. The compose file publishes it on TAILSCALE_IP only.
PORT=3000

# SQLite location (inside the container this resolves to the ./data volume).
DB_PATH=data/app.db

# --- Tailscale-only exposure (PLAN.md §7) --------------------------------
# The Mac Mini's tailnet IPv4 address: `tailscale ip -4`. Used only by
# docker-compose to decide which host interface the port is published on.
# Leave unset to keep the dashboard reachable from this machine only.
TAILSCALE_IP=

# --- Email (PLAN.md §5) — required when DRY_RUN=false --------------------
# Gmail: smtp.gmail.com:587 with an app password (2FA account), or Resend:
# smtp.resend.com:587, user "resend", password = API key.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=delft.rental.alert@gmail.com
SMTP_PASS=app-password-here
MAIL_FROM=Delft Rental Alert <delft.rental.alert@gmail.com>

# --- Scraping ------------------------------------------------------------
# Master switch for the scrape loops (the API/dashboard always run). `pnpm
# dev` forces this off so UI work never polls the live sites.
SCRAPERS_ENABLED=true

# Poll intervals (PLAN.md §3: 60-180s; scheduler adds ±20% jitter). The first
# poll after a (re)start waits one full interval; after a 403/429 the backoff
# (5m/30m/2h) survives restarts via scrape_runs.
POLL_INTERVAL_PARARIUS_SEC=120
POLL_INTERVAL_HUURWONINGEN_SEC=150
POLL_INTERVAL_FUNDA_SEC=180
POLL_INTERVAL_HUURE_SEC=180
POLL_INTERVAL_APPARTEMENTDELFT_SEC=180
POLL_INTERVAL_BJORND_SEC=180
POLL_INTERVAL_OUDEDELFT_SEC=180
POLL_INTERVAL_IKWILHUREN_SEC=180
POLL_INTERVAL_HUURWONINGPORTAAL_SEC=180
POLL_INTERVAL_RENTFINDER_SEC=180
POLL_INTERVAL_HUISLIJN_SEC=180
POLL_INTERVAL_HUIZENVINDER_SEC=180
POLL_INTERVAL_RENT_SEC=180
POLL_INTERVAL_DIRECTWONEN_SEC=180
POLL_INTERVAL_VBT_SEC=180
POLL_INTERVAL_MARKTPLAATS_SEC=180
POLL_INTERVAL_BUURTJE_SEC=180
# Aggregators: vrijwel pure duplicaten van primaire bronnen, dus rustiger gepolld.
POLL_INTERVAL_HUURSTUNT_SEC=600
POLL_INTERVAL_RENTUMO_SEC=600
POLL_INTERVAL_RENTOLA_SEC=600
POLL_INTERVAL_TROVIT_SEC=600
# Inschrijfsystemen: geen snelheidsspel, dus rustiger gepolld.
POLL_INTERVAL_WOONNET_SEC=300
POLL_INTERVAL_ROOMMATCH_SEC=300

# --- Dashboard (PLAN.md §6) ----------------------------------------------
# Password for the built-in `admin` dashboard login (sees all profiles/matches
# and the health page). Friends log in with the username/password set on their
# profile and only see their own matches. Unset = admin login disabled.
DASHBOARD_PASSWORD=

# Recipient for scraper health alerts (no successful run >30 min, or 5x zero
# listings in a row). Leave empty to only log alerts.
ADMIN_EMAIL=
